# ── App ──────────────────────────────────────────────────────────────
APP_NAME="AI Media Publisher"
DEBUG=false

# ── Database (PostgreSQL) ────────────────────────────────────────────
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=media_publisher

# ── Security ─────────────────────────────────────────────────────────
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# ── LLM Provider ─────────────────────────────────────────────────────
# 可选值: openai | anthropic
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Platform Publish Tokens ──────────────────────────────────────────
# GitHub: 需要 gist 权限的 Personal Access Token
GITHUB_TOKEN=ghp_...
GITHUB_GIST_PUBLIC=false

# CSDN: 从 https://mp.csdn.net 开发者后台申请
CSDN_API_KEY=

# 小红书: Cookie JSON 字符串，从浏览器开发者工具获取
# 格式: {"web_session": "xxx", "a1": "xxx", ...}
XHS_COOKIES=
